<script>

  window.addEventListener('DOMContentLoaded', () => {
    const hash = window.location.hash;

    if (hash === '#match-history') {
      const target = document.querySelector(hash);
      if (!target) return;

      const offset = 80; // adjust if you have a fixed header
      const duration = 1000;

      const targetPosition = target.getBoundingClientRect().top + window.scrollY - offset;
      const startPosition = window.scrollY;
      const distance = targetPosition - startPosition;
      let startTime = null;

      function animation(currentTime) {
        if (!startTime) startTime = currentTime;
        const timeElapsed = currentTime - startTime;
        const run = easeInOutQuad(timeElapsed, startPosition, distance, duration);
        window.scrollTo(0, run);
        if (timeElapsed < duration) requestAnimationFrame(animation);
      }

      function easeInOutQuad(t, b, c, d) {
        t /= d / 2;
        if (t < 1) return c / 2 * t * t + b;
        t--;
        return -c / 2 * (t * (t - 2) - 1) + b;
      }

      requestAnimationFrame(animation);
    }


  });

  document.addEventListener("DOMContentLoaded", () => {
    const tabs = document.querySelectorAll(".tab-container-mh .tab");
    const path = window.location.pathname.toLowerCase(); // e.g. /match-history/mbappe

    tabs.forEach(tab => {
      const player = tab.dataset.target.toLowerCase();

      // Highlight active tab based on URL
      if (path.includes(player)) {
        tab.classList.add("active");
      } else {
        tab.classList.remove("active");
      }

      // Add click event → go to corresponding player page
      tab.addEventListener("click", () => {
        window.location.href = `/Match-History/${player}#match-history`;
      });
    });
  });



  document.getElementById('toggleAdvanced').addEventListener('click', () => {
    const adv = document.getElementById('advancedFilters');
    const arrow = document.getElementById('arrow');
    adv.classList.toggle('hidden');
    arrow.textContent = adv.classList.contains('hidden') ? '▾' : '▴';
  });


  // Funtion to toggle match card details and scroll into view if expanding

  function toggleCardDetails(button) {
    const card = button.closest('.cardNew-card');
    if (!card) return;

    const expanded = card.querySelector('.cardNew-expanded');
    if (!expanded) return;

    expanded.classList.toggle('hidden');

    const isHidden = expanded.classList.contains('hidden');
    button.textContent = isHidden ? "Details ▲" : "Details ▼";
  }



  function toggleDropdown(button) {
    const dropdown = button.nextElementSibling;
    dropdown.classList.toggle('hidden');
  }

  // Optional: Close on outside click
  document.addEventListener('click', function (e) {
    document.querySelectorAll('.dropdown-checkbox').forEach(drop => {
      if (!drop.contains(e.target)) {
        drop.querySelector('.dropdown-options').classList.add('hidden');
      }
    });
  });

  // Report form popup and send script
  const statsPopup = document.getElementById("statsPopup");
  const openStatsPopupBtns = document.querySelectorAll("#openStatsPopup, #openInaccuratePopup"); // multiple buttons
  const closeStatsPopupBtn = document.getElementById("closeStatsPopup");
  const statsReportForm = document.getElementById("statsReportForm");

  // Loading + Success popups
  const sendingPopup = document.getElementById("emailSendingPopup");
  const successPopup = document.getElementById("mvhvSuccessPopup");

  // Open popup (loop through all trigger buttons)
  openStatsPopupBtns.forEach(btn => {
    btn.addEventListener("click", () => {
      statsPopup.style.display = "flex";
    });
  });

  // Close popup
  closeStatsPopupBtn.addEventListener("click", () => {
    statsPopup.style.display = "none";
  });

  // Submit form
  statsReportForm.addEventListener("submit", async (e) => {
    e.preventDefault();

    const formData = {
      email: document.getElementById("email").value,
      statTitle: document.getElementById("matchId").value, // backend expects "statTitle" but we map it from matchId
      currentStat: document.getElementById("statName").value,
      correctStat: document.getElementById("correctStat").value,
      extra: document.getElementById("extra").value
    };

    try {
      // Show "Please wait" popup
      sendingPopup.style.display = "flex";

      const res = await fetch("/send-inaccurate-report", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(formData)
      });

      // Hide sending popup
      sendingPopup.style.display = "none";

      if (res.ok) {
        // Show success popup
        successPopup.style.display = "flex";

        // Auto-hide after 3s
        setTimeout(() => {
          successPopup.style.display = "none";
        }, 3000);

        // Reset form & close modal
        statsPopup.style.display = "none";
        statsReportForm.reset();
      } else {
        alert("Failed to submit. Please try again.");
      }
    } catch (err) {
      console.error(err);
      sendingPopup.style.display = "none"; // hide wait popup if error
      alert("Something went wrong. Please try again later.");
    }
  });

  document.getElementById("openMobilePopup").addEventListener("click", () => {
    document.getElementById("statsPopup2").classList.remove("hidden");
  });

  document.getElementById("closePopup").addEventListener("click", () => {
    document.getElementById("statsPopup2").classList.add("hidden");
  });

  // add match
  const addMatchPopup = document.getElementById("addMatchPopup");
  const openAddMatchBtn = document.getElementById("openAddMatchPopup");
  const closeAddMatchBtn = document.getElementById("closeAddMatchPopup");
  const addMatchForm = document.getElementById("addMatchForm");
  const addMatchLoadingPopup = document.getElementById(
    "add-match-loading-popup"
  );

  const addMatchLoadingTitle = document.getElementById(
    "add-match-loading-title"
  );

  const addMatchLoadingMessage = document.getElementById(
    "add-match-loading-message"
  );

  // Open popup
  openAddMatchBtn.addEventListener("click", () => {
    addMatchPopup.style.display = "flex";
  });

  // Close popup
  closeAddMatchBtn.addEventListener("click", () => {
    addMatchPopup.style.display = "none";
  });

  // Submit form
  addMatchForm.addEventListener("submit", async (e) => {
    e.preventDefault();

    const formData = Object.fromEntries(
      new FormData(addMatchForm).entries()
    );

    if (formData.goalTypes) {
      formData.goalTypes = formData.goalTypes
        .split(',')
        .map(s => s.trim())
        .join(',');
    }

    const submitBtn = addMatchForm.querySelector(
      'button[type="submit"]'
    );

    submitBtn.disabled = true;

    addMatchLoadingTitle.textContent = "Please Wait";
    addMatchLoadingMessage.textContent =
      "Adding match and generating posts...";

    addMatchLoadingPopup.style.display = "flex";

    try {
      const res = await fetch("/admin/add-match", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify(formData)
      });

      const result = await res.json();

      if (result.success) {
        addMatchLoadingTitle.textContent = "Success";
        addMatchLoadingMessage.textContent =
          "Match added successfully!";

        setTimeout(() => {
          addMatchLoadingPopup.style.display = "none";

          addMatchForm.reset();
          addMatchPopup.style.display = "none";

        }, 1200);

      } else {
        addMatchLoadingTitle.textContent = "Failed";
        addMatchLoadingMessage.textContent =
          result.error || "Failed to add match";
      }

    } catch (err) {
      console.error(err);

      addMatchLoadingTitle.textContent = "Error";
      addMatchLoadingMessage.textContent =
        err.message || "Something went wrong";
    } finally {
      submitBtn.disabled = false;
    }
  });

  //Modify and delete
  document.addEventListener("DOMContentLoaded", () => {
    let currentMatchNo = null; // ✅ SHARED STATE
    const matchPopup = document.getElementById("matchPopup");
    const openMatchPopupBtn = document.getElementById("openMatchPopup");
    const closeMatchPopupBtn = document.getElementById("closeMatchPopup");
    const matchForm = document.getElementById("matchForm");
    const fetchMatchBtn = document.getElementById("fetchMatch");
    const deleteMatchBtn = document.getElementById("deleteMatch");
    const playerSelect = document.getElementById("playerSelect");
    const matchDateInput = document.getElementById("matchDate-fetch");


    // Open popup
    openMatchPopupBtn.addEventListener("click", () => {
      matchPopup.style.display = "flex";
    });


    // Close popup
    closeMatchPopupBtn.addEventListener("click", () => {
      matchPopup.style.display = "none";
      matchForm.reset();
    });

    // Fetch existing match data
    fetchMatchBtn.addEventListener("click", async () => {
      const playerTable = playerSelect.value;
      const matchDate = matchDateInput.value;

      if (!playerTable) return alert("Select a player!");
      if (!matchDate) return alert("Enter a match date!");

      try {
        const res = await fetch(`/admin/get-match/${matchDate}?playerTable=${playerTable}`);
        const data = await res.json();

        if (!data.success) return alert(data.error || "Match not found");

        currentMatchNo = data.match.No;

        // Fill the form with fetched data
        Object.keys(data.match).forEach(key => {
          const input = matchForm.querySelector(`[name=${key}]`);
          if (input) input.value = data.match[key];
        });

      } catch (err) {
        console.error(err);
        alert("Failed to fetch match data");
      }

    });


    // Modify match
    matchForm.addEventListener("submit", async (e) => {
      e.preventDefault();

      const playerTable = playerSelect.value;

      if (!currentMatchNo) {
        return alert("Fetch a match first");
      }

      const formData = Object.fromEntries(new FormData(matchForm).entries());


      try {
        const res = await fetch('/admin/match-action', {
          method: 'POST',
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            action: "modify",
            matchNumber: currentMatchNo,
            playerTable,
            data: formData
          })
        });

        const result = await res.json();

        if (result.success) {
          alert("Match updated successfully!");
          matchForm.reset();
          matchPopup.style.display = "none";
          currentMatchNo = null; // ✅ RESET STATE
        } else {
          alert(result.error || "Failed to update match");
        }
      } catch (err) {
        console.error(err);
        alert("Error updating match");
      }
    });

    // Delete match
    deleteMatchBtn.addEventListener("click", async () => {
      const playerTable = document.getElementById("playerSelect").value;

      if (!currentMatchNo) {
        return alert("Fetch a match first");
      }

      if (!confirm("Are you sure you want to delete this match?")) return;

      const matchNumber = currentMatchNo;

      try {
        const res = await fetch('/admin/match-action', {
          method: 'POST',
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            action: "delete",
            matchNumber,
            playerTable
          })
        });

        const result = await res.json();

        if (result.success) {
          alert("Match deleted successfully!");
          matchForm.reset();
          matchPopup.style.display = "none";
          currentMatchNo = null; // ✅ RESET STATE
        } else {
          alert(result.error || "Failed to delete match");
        }
      } catch (err) {
        console.error(err);
        alert("Error deleting match");
      }
    });

  });
</script>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const competitionSelect = document.getElementById('competition');
    const stageSelect = document.getElementById('stage');
    const seasonSelect = document.getElementById('season');
    const yearSelect = document.getElementById('year');
    const minGoalsInput = document.getElementById('minGoals');
    const minAssistsInput = document.getElementById('minAssists');
    const chancesCreatedInput = document.getElementById('chancesCreated');
    const bigChancesCreatedInput = document.getElementById('bigChancesCreated');
    const dribblesInput = document.getElementById('dribbles');
    const minutesPlayedInput = document.getElementById('minutesPlayed');
    const resultSelect = document.getElementById('rest');
    const goalTypeCheckboxes = document.querySelectorAll('.goal-type');
    const forTeamSelect = document.getElementById('for');
    const againstTeamInput = document.getElementById('against');
    const matchNoInput = document.getElementById('matchNo');
    const matchDateInput = document.getElementById('matchDate');
    const loadMoreBtn = document.getElementById('load-more');
    const container = document.getElementById('matches-container');
    const clearFiltersBtn = document.getElementById('clearFiltersBtn');
    const sortBtn = document.getElementById('sortBtn');
    const sortPopup = document.getElementById('sortPopup');
    const sortRadios = document.querySelectorAll('input[name="sort"]');
    const limitMatchesInput = document.getElementById('limitMatches');

    let currentOffset = 0;
    let currentLimit = 100;

    // Current filter states
    let currentCompetition = '';
    let currentMinGoals = 0;
    let currentMinAssists = 0;
    let currentCC = 0;
    let currentBCC = 0;
    let currentDribbles = 0;
    let currentMnt = 0;
    let currentStage = '';
    let currentSeason = '';
    let currentYear = '';
    let currentResult = '';
    let currentForTeam = '';
    let currentAgainstTeam = '';
    let currentGoalTypes = [];
    let currentMatchNo = '';
    let currentMatchDate = '';
    let currentSort = '';
    let currentLimitMatches = 0;

    // Get the player from the current URL path
    let pathParts = window.location.pathname.split('/');
    let currentPlayer = pathParts[pathParts.length - 1] || 'vinicius';

    function applyFilters() {
      currentCompetition = competitionSelect.value;
      currentMinGoals = parseInt(minGoalsInput.value) || 0;
      currentMinAssists = parseInt(minAssistsInput.value) || 0;
      currentCC = parseInt(chancesCreatedInput.value) || 0;

      currentBCC = parseInt(bigChancesCreatedInput.value) || 0;


      currentDribbles = parseInt(dribblesInput.value) || 0;
      currentMnt = parseInt(minutesPlayedInput.value) || 0;
      currentStage = stageSelect.value;
      currentSeason = seasonSelect.value;
      currentYear = yearSelect.value;
      currentResult = resultSelect.value;
      currentForTeam = forTeamSelect.value;
      currentAgainstTeam = againstTeamInput.value.trim();
      currentGoalTypes = Array.from(goalTypeCheckboxes)
        .filter(cb => cb.checked)
        .map(cb => cb.value);
      currentMatchNo = matchNoInput.value;
      currentMatchDate = matchDateInput.value;
      currentLimitMatches = parseInt(limitMatchesInput.value) || 0;

      currentOffset = 0;
      fetchMatches(
        currentOffset,
        currentLimit,
        currentCompetition,
        currentMinGoals,
        currentMinAssists,
        currentCC,
        currentBCC,
        currentDribbles,
        currentMnt,
        currentStage,
        currentSeason,
        currentYear,
        currentResult,
        currentForTeam,
        currentAgainstTeam,
        currentGoalTypes,
        true,
        currentMatchNo,
        currentMatchDate,
        currentLimitMatches
      );

    }

    // Event listeners for filters
    [
      competitionSelect, stageSelect, seasonSelect, yearSelect, resultSelect, forTeamSelect
    ].forEach(el => el.addEventListener('change', applyFilters));

    [
      minGoalsInput, minAssistsInput, chancesCreatedInput, bigChancesCreatedInput, dribblesInput, minutesPlayedInput,
      againstTeamInput, matchNoInput
    ].forEach(el => el.addEventListener('input', applyFilters));

    matchDateInput.addEventListener('change', applyFilters);
    goalTypeCheckboxes.forEach(cb => cb.addEventListener('change', applyFilters));
    limitMatchesInput.addEventListener('input', applyFilters);

    clearFiltersBtn?.addEventListener('click', () => {
      document.querySelectorAll('select').forEach(select => select.value = 'All');
      document.querySelectorAll('input[type="number"], input[type="text"], input[type="date"]').forEach(input => input.value = '');
      document.querySelectorAll('input[type="checkbox"]').forEach(cb => cb.checked = false);
      applyFilters();
    });

    // Sorting
    sortBtn?.addEventListener('click', () => sortPopup.classList.toggle('hidden'));

    sortRadios.forEach(radio => radio.addEventListener('change', () => {
      currentSort = radio.value;
      sortPopup.classList.add('hidden');
      applyFilters();
    }));

    document.addEventListener('click', (e) => {
      if (!sortPopup.contains(e.target) && !sortBtn.contains(e.target)) {
        sortPopup.classList.add('hidden');
      }
    });


    loadMoreBtn?.addEventListener('click', () => {
      fetchMatches(
        currentOffset,
        currentLimit,
        currentCompetition,
        currentMinGoals,
        currentMinAssists,
        currentCC,
        currentBCC,
        currentDribbles,
        currentMnt,
        currentStage,
        currentSeason,
        currentYear,
        currentResult,
        currentForTeam,
        currentAgainstTeam,
        currentGoalTypes,
        false,
        currentMatchNo,
        currentMatchDate,
        currentLimitMatches
      );
    });

    // -------------------- Loading overlay helper --------------------
    let _mhvLoadingTimer = null;
    let _mhvLoadingShown = false;

    function ensureLoadingOverlay() {
      if (document.getElementById('mhv-loading-overlay')) return;
      const overlay = document.createElement('div');
      overlay.id = 'mhv-loading-overlay';
      overlay.innerHTML = `
  <div class="loader" aria-hidden="true"></div>
`;
      document.body.appendChild(overlay);
    }

    function showLoadingOverlayImmediate() {
      ensureLoadingOverlay();
      const overlay = document.getElementById('mhv-loading-overlay');
      overlay.classList.add('show');
      _mhvLoadingShown = true;
    }

    function hideLoadingOverlay() {
      const overlay = document.getElementById('mhv-loading-overlay');
      if (!overlay) return;
      overlay.classList.remove('show');
      _mhvLoadingShown = false;
    }

    function startLoadingGuard() {
      // If there's an existing timer, clear it first
      clearTimeout(_mhvLoadingTimer);
      // Only show overlay when operation takes longer than 1000ms
      _mhvLoadingTimer = setTimeout(() => {
        showLoadingOverlayImmediate();
      }, 1000);
    }

    function stopLoadingGuard() {
      // Cancel scheduled show
      clearTimeout(_mhvLoadingTimer);
      _mhvLoadingTimer = null;
      // If overlay already visible, hide it immediately
      if (_mhvLoadingShown) hideLoadingOverlay();
    }
    // -------------------- /Loading overlay helper --------------------

    //Load matches with current filters
    function fetchMatches(offset, limit, competition, minGoals, minAssists, CC, BCC, dribbles, mnt, stage, season, year, result, forTeam, againstTeam, goalTypes, reset, matchNo, matchDate, limitMatches) {
      const isAdmin = window.location.pathname.startsWith('/admin');

      const basePath = isAdmin
        ? '/admin/Match-History/'
        : '/Match-History/';

      let url = `${basePath}${encodeURIComponent(currentPlayer)}?offset=${offset}&limit=${limit}`;

      if (currentSort) url += `&sort=${encodeURIComponent(currentSort)}`;
      if (competition && competition !== 'All') url += `&competition=${encodeURIComponent(competition)}`;
      if (minGoals > 0) url += `&minGoals=${minGoals}`;
      if (minAssists > 0) url += `&minAssists=${minAssists}`;
      if (CC > 0) url += `&CC=${CC}`;
      if (BCC > 0) url += `&minBCC=${BCC}`;
      if (dribbles > 0) url += `&dribbles=${dribbles}`;
      if (mnt > 0) url += `&mnt=${mnt}`;
      if (stage && stage !== 'All') url += `&stage=${encodeURIComponent(stage)}`;
      if (season && season !== 'All') url += `&season=${encodeURIComponent(season)}`;
      if (year && year !== 'All') url += `&year=${encodeURIComponent(year)}`;
      if (result && result !== 'All') url += `&result=${encodeURIComponent(result)}`;
      if (forTeam && forTeam !== 'All') url += `&forTeam=${encodeURIComponent(forTeam)}`;
      if (againstTeam) url += `&againstTeam=${encodeURIComponent(againstTeam)}`;
      if (goalTypes.length > 0) url += `&goalTypes=${encodeURIComponent(goalTypes.join(','))}`;
      if (matchNo) url += `&matchNo=${encodeURIComponent(matchNo)}`;
      if (matchDate) url += `&matchDate=${encodeURIComponent(matchDate)}`;
      if (limitMatches > 0) url += `&limitMatches=${limitMatches}`;

      startLoadingGuard();


      fetch(url)
        .then(res => res.text())
        .then(html => {
          const parser = new DOMParser();
          const doc = parser.parseFromString(html, 'text/html');

          log("Fetched totalGoals:", doc.querySelector('#totalGoals')?.textContent);
          log("Fetched totalAssists:", doc.querySelector('#totalAssists')?.textContent);
          log("Fetched totalCC:", doc.querySelector('#totalCC')?.textContent);
          log("Fetched totalBCC:", doc.querySelector('#totalBCC')?.textContent);
          log("Fetched totalDribbles:", doc.querySelector('#totalDribbles')?.textContent);

          const newMatches = doc.querySelectorAll('#matches-container .match-card');

          if (reset) container.innerHTML = '';
          if (newMatches.length === 0) {
            container.innerHTML = `<div id="noMatchesMessage">No matches found.</div>`;
          } else {
            newMatches.forEach(card => container.appendChild(card));

          }

          currentOffset += limit;

          const currentMatchCountEls = document.querySelectorAll('.match-count');
          const newMatchCountEls = doc.querySelectorAll('.match-count');

          if (currentMatchCountEls.length && newMatchCountEls.length) {
            currentMatchCountEls.forEach((el, index) => {
              if (newMatchCountEls[index]) {
                el.textContent = newMatchCountEls[index].textContent;
              }
            });
          }

          const newTotalGoalsEl = doc.querySelector('#totalGoals');
          const newTotalAssistsEl = doc.querySelector('#totalAssists');
          const newTotalCCEl = doc.querySelector('#totalCC');
          const newTotalBCCEl = doc.querySelector('#totalBCC');
          const newTotalDribblesEl = doc.querySelector('#totalDribbles');
          const newTotalMinutesEl = doc.querySelector('#totalMinutes');
          const newTotalShotEl = doc.querySelector('#totalShot');
          const newTotalPenEl = doc.querySelector('#totalPen');
          const newTotalHattricksEl = doc.querySelector('#totalHattricks');
          const newGoalRatioEl = doc.querySelector('#goalRatio');

          if (
            newTotalGoalsEl &&
            newTotalAssistsEl &&
            newTotalCCEl &&
            newTotalBCCEl &&
            newTotalDribblesEl &&
            newTotalMinutesEl &&
            newTotalShotEl &&
            newTotalPenEl &&
            newTotalHattricksEl
          ) {
            document.getElementById('totalGoals').textContent = newTotalGoalsEl.textContent;
            document.getElementById('totalAssists').textContent = newTotalAssistsEl.textContent;
            document.getElementById('totalCC').textContent = newTotalCCEl.textContent;
            document.getElementById('totalBCC').textContent = newTotalBCCEl.textContent;
            document.getElementById('totalDribbles').textContent = newTotalDribblesEl.textContent;
            document.getElementById('totalMinutes').textContent = newTotalMinutesEl.textContent;
            document.getElementById('totalShot').textContent = newTotalShotEl.textContent;
            document.getElementById('totalPen').textContent = newTotalPenEl.textContent;
            document.getElementById('totalHattricks').textContent = newTotalHattricksEl.textContent;
            document.getElementById('goalRatio').textContent = newGoalRatioEl.textContent;
          }

          const newLoadMoreBtn = doc.getElementById('load-more');
          loadMoreBtn.style.display = newLoadMoreBtn ? 'block' : 'none';

          stopLoadingGuard();

          showPopup?.(`${newMatches.length} matches loaded!`);
        })
        .catch(err => console.error(err));
    }

    // Automatically fetch first matches on page load
    applyFilters();


  });

  // Create the popup element once
  let popupMessage = document.createElement('div');
  popupMessage.id = 'popupMessage';
  document.body.appendChild(popupMessage);

  // Show popup function
  function showPopup(msg) {
    popupMessage.textContent = msg;
    popupMessage.classList.add('show');

    setTimeout(() => {
      popupMessage.classList.remove('show');
    }, 1000);
  }

  // Hide the initial loading spinner after 1 second
  setTimeout(() => {
    const overlay = document.getElementById('mhv-loading-overlay');
    if (overlay) overlay.classList.remove('show');
  }, 800);

</script>

<script>
  function colorStats() {
    document.querySelectorAll('.cardNew-statNum').forEach(el => {
      const value = Number(el.textContent.trim());
      if (value > 0) el.classList.add('gold');
    });
  }

  const observer = new MutationObserver(() => {
    colorStats();
  });

  observer.observe(document.body, {
    childList: true,
    subtree: true,
    characterData: true
  });
</script>

<script>
  //delete button match card
  async function deleteMatch(matchNumber, player) {

    const tableMap = {
      mbappe: 'mhmbappe',
      haaland: 'mhhaaland',
      vinicius: 'mhvinicius'
    };

    const playerTable = tableMap[player];

    console.log("DELETE:", matchNumber, player, playerTable);

    if (!playerTable) {
      alert("Invalid player");
      return;
    }

    if (!confirm(`Delete match #${matchNumber}?`)) return;

    try {
      const res = await fetch('/admin/match-action', {
        method: 'POST',
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          action: "delete",
          matchNumber,
          playerTable
        })
      });

      const result = await res.json();

      if (result.success) {
        alert("Deleted");
        document.querySelector(`[data-match="${matchNumber}"]`)?.remove();
      } else {
        alert(result.error || "Failed");
      }

    } catch (err) {
      console.error(err);
      alert("Error deleting");
    }
  }

</script>